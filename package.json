{
  "name": "@phcdevworks/spectre-signals",
  "version": "1.0.0",
  "description": "Minimal, framework-agnostic reactive primitives package for Spectre applications.",
  "keywords": [
    "phcdevworks",
    "spectre",
    "spectre-shell",
    "spectre-shell-signals",
    "spectre-signals",
    "signals",
    "reactivity",
    "typescript",
    "framework-agnostic",
    "reactive-primitives",
    "computed",
    "effect",
    "signal"
  ],
  "author": "PHCDevworks",
  "license": "MIT",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/phcdevworks"
    },
    {
      "type": "buymeacoffee",
      "url": "https://buymeacoffee.com/phcdevworks"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phcdevworks/spectre-shell-signals.git"
  },
  "bugs": {
    "url": "https://github.com/phcdevworks/spectre-shell-signals/issues"
  },
  "homepage": "https://github.com/phcdevworks/spectre-shell-signals#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "clean": "rm -rf dist",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "cSpell.words": [
    "phcdevworks"
  ]
}
