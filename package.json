{
  "name": "@phcdevworks/spectre-shell-signals",
  "version": "1.1.0",
  "description": "Minimal, framework-agnostic reactive primitives package for Spectre applications.",
  "keywords": [
    "phcdevworks",
    "spectre",
    "spectre-shell",
    "spectre-shell-signals",
    "spectre-signals",
    "signals",
    "reactivity",
    "typescript",
    "framework-agnostic",
    "reactive-primitives",
    "computed",
    "effect",
    "signal"
  ],
  "author": "PHCDevworks",
  "license": "MIT",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/phcdevworks"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phcdevworks/spectre-shell-signals.git"
  },
  "bugs": {
    "url": "https://github.com/phcdevworks/spectre-shell-signals/issues"
  },
  "homepage": "https://github.com/phcdevworks/spectre-shell-signals#readme",
  "type": "module",
  "packageManager": "npm@11.16.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": "^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "release:propose": "jiti scripts/propose-version.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:md": "prettier --write \"**/*.md\"",
    "format:md:check": "prettier --check \"**/*.md\"",
    "test": "vitest run",
    "check:ecosystem": "spectre-manifest-validate spectre.manifest.json && spectre-manifest-check spectre.manifest.json .",
    "check": "npm run typecheck && npm run lint && npm run build && npm run test && npm run check:ecosystem",
    "prepublishOnly": "npm run check"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@phcdevworks/spectre-manifest": "^1.0.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
